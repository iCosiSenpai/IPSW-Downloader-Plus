/* WelcomeView */
"welcome.title" = "Benvenuto in IPSW Downloader Plus!";
"welcome.hero.body" = "Mantieni aggiornate le cartelle firmware Apple con un flusso batch più veloce e sicuro.";
"welcome.card.downloads.title" = "Download batch";
"welcome.card.downloads.body" = "Scarica gli IPSW firmati più recenti per molti dispositivi con coda, retry e ripresa del download.";
"welcome.card.setup.title" = "Setup guidato";
"welcome.card.setup.body" = "Subito dopo questa schermata di benvenuto, l'app apre una configurazione iniziale dedicata a permessi e cartelle.";
"welcome.flow.note" = "Vai avanti per i prossimi passi";
"welcome.description1" = "IPSW Downloader Plus scarica in batch i firmware IPSW più recenti da Apple e li posiziona nelle cartelle corrette di iTunes Software Updates o Apple Configurator Firmware, così da essere rilevati automaticamente da Finder e/o Apple Configurator.";
"welcome.description2" = "Puoi configurare quali firmware scaricare per tipo di dispositivo: iPhone, iPad, iPod touch, Apple TV, HomePod mini, Apple Vision, T2 Mac (iBridge) e Apple Silicon Mac. Puoi anche pianificare un avvio automatico per mantenere sempre aggiornati tutti i tuoi firmware IPSW.";
"welcome.fda.title" = "Accesso completo al disco";
"welcome.fda.body" = "Per gestire la cartella Apple Configurator Firmware, abilita Full Disk Access in Impostazioni di Sistema → Privacy e Sicurezza → Accesso completo al disco.";
"welcome.fda.button" = "Apri Privacy e Sicurezza…";
"welcome.fda.granted" = "Concesso";
"welcome.fda.denied" = "Mancante";
"welcome.fda.unknown" = "Non verificato";
"welcome.fda.granted.body" = "Full Disk Access è attivo. IPSW Downloader Plus può scrivere in tutte le cartelle necessarie.";
"welcome.fda.unknown.body" = "macOS non ha esposto abbastanza percorsi protetti per verificare automaticamente il Full Disk Access. Puoi comunque continuare, ma le cartelle Apple di default potrebbero fallire finché il permesso non viene concesso.";
"welcome.fda.recheck" = "Verifica di nuovo il permesso";
"welcome.fda.step1" = "Apri Impostazioni di Sistema → Privacy e Sicurezza → Accesso completo al disco";
"welcome.fda.step2" = "Clicca il pulsante + e aggiungi IPSW Downloader Plus";
"welcome.fda.step3" = "Attiva il toggle accanto all'app, poi torna qui e clicca \"Verifica di nuovo il permesso\"";
"fda.required.title" = "Accesso Completo Al Disco Richiesto";
"fda.required.body" = "IPSW Downloader Plus scrive i firmware direttamente nelle vere cartelle della Libreria utente, come ~/Library/iTunes e la cache firmware di Apple Configurator. Concedi subito il Full Disk Access prima di usare l'app.";
"fda.required.quit" = "Esci";
"welcome.folders.title" = "Cartelle gestite";
"welcome.folders.itunes.title" = "iPhone · iPad · iPod touch";
"welcome.folders.itunes.desc" = "Salvati in iTunes Software Updates — rilevati sia da Finder che da Apple Configurator.";
"welcome.folders.configurator.title" = "Apple TV · HomePod mini · Apple Vision · T2 Mac (iBridge) · Apple Silicon Mac";
"welcome.folders.configurator.desc" = "Salvati nella cartella Firmware di Apple Configurator. Apple Configurator NON rileva firmware di questi dispositivi nella cartella iTunes.";
"welcome.folders.show_in_finder" = "Mostra in Finder";
"welcome.reorganize.title" = "Gestione automatica dei file esistenti";
"welcome.reorganize.body" = "Accettando, IPSW Downloader Plus prenderà in gestione queste due cartelle. I file .ipsw già presenti verranno riorganizzati automaticamente:";
"welcome.reorganize.bullet1" = "I firmware iPhone/iPad/iPod trovati nella cartella Configurator verranno spostati nella cartella iTunes corretta.";
"welcome.reorganize.bullet2" = "I firmware Apple TV, HomePod, Mac trovati nella cartella iTunes verranno spostati nella cartella Configurator.";
"welcome.reorganize.bullet3" = "I firmware ancora firmati da Apple ma non aggiornati verranno lasciati invariati.";
"welcome.reorganize.bullet4" = "I firmware non più firmati da Apple verranno eliminati o spostati nel Cestino (secondo le tue impostazioni).";
"welcome.reorganize.bullet5" = "Ogni volta che viene scaricata una versione più recente, quella precedente verrà rimossa.";
"welcome.excluded.title" = "Dispositivi esclusi automaticamente";
"welcome.excluded.body" = "I seguenti dispositivi vengono sempre ignorati perché irrilevanti o bloccati a versioni obsolete:";
"welcome.excluded.bullet1" = "ADP3,2 — Apple Silicon Developer Transition Kit (bloccato a macOS 11.2.3, non aggiornabile)";
"welcome.excluded.bullet2" = "VirtualMac — Apple Silicon Virtual Machine (istanza virtuale ridondante)";
"welcome.schedule.title" = "Pianificazione automatica — note importanti";
"welcome.schedule.warning" = "Per la funzione di avvio automatico programmato è necessario che il Login Automatico sia abilitato sul Mac (Impostazioni di Sistema → Utenti e Gruppi). Senza login automatico, il Mac non può eseguire task pianificati quando è spento o riavviato.";
"welcome.schedule.body" = "La pianificazione usa un LaunchAgent di macOS (~/Library/LaunchAgents/com.icosisenpai.ipsw-downloader-plus.plist) che avvia l'app all'orario impostato. Solo i download firmati e attivi vengono eseguiti.";
"welcome.security.title" = "Sicurezza e verifica";
"welcome.security.bullet1" = "Tutti i firmware vengono scaricati solo da domini Apple ufficiali (appldnld.apple.com, updates.cdn-apple.com).";
"welcome.security.bullet2" = "Dopo ogni download viene verificato il checksum SHA1 fornito dall'API ipsw.me.";
"welcome.security.bullet3" = "I file con dimensione o checksum errati vengono automaticamente riscartati e riscaricati.";
"welcome.security.fda_required.title" = "Il Full Disk Access è obbligatorio per le cartelle di default";
"welcome.security.fda_required.body" = "Se vuoi che IPSW Downloader Plus salvi direttamente nelle cartelle standard di iTunes e Apple Configurator, il Full Disk Access è obbligatorio. Senza quel permesso l'app non può scriverci.";
"welcome.security.fda_required.custom" = "È attiva una destinazione personalizzata in %@. In questo caso l'app può salvare lì anche senza Full Disk Access, ma non userà più le cartelle Apple di default.";
