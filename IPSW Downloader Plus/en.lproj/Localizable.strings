/* WelcomeView */
"welcome.title" = "Welcome to IPSW Downloader Plus!";
"welcome.hero.body" = "Keep Apple firmware folders updated with a faster, safer batch workflow.";
"welcome.card.downloads.title" = "Batch downloads";
"welcome.card.downloads.body" = "Download the latest signed IPSW files for many devices with queueing, retry and resume support.";
"welcome.card.setup.title" = "Guided setup";
"welcome.card.setup.body" = "Right after this welcome screen, the app opens a dedicated setup flow for permissions and destination folders.";
"welcome.flow.note" = "Go ahead for the next setup steps.";
"welcome.description1" = "IPSW Downloader Plus batch-downloads the latest IPSW firmware from Apple and places them in the correct iTunes Software Updates or Apple Configurator Firmware folders, so they are automatically detected by Finder and/or Apple Configurator.";
"welcome.description2" = "You can configure which firmware to download by device type: iPhone, iPad, iPod touch, Apple TV, HomePod mini, Apple Vision, T2 Mac (iBridge) and Apple Silicon Mac. You can also schedule an automatic launch to keep all your IPSW firmware up to date.";
"welcome.fda.title" = "Full Disk Access";
"welcome.fda.body" = "To manage the Apple Configurator Firmware folder, enable Full Disk Access in System Settings → Privacy & Security → Full Disk Access.";
"welcome.fda.button" = "Open Privacy & Security…";
"welcome.fda.granted" = "Granted";
"welcome.fda.denied" = "Missing";
"welcome.fda.unknown" = "Not verified";
"welcome.fda.granted.body" = "Full Disk Access is active. IPSW Downloader Plus can write to all required folders.";
"welcome.fda.unknown.body" = "macOS did not expose enough protected locations to verify Full Disk Access automatically. You can still continue, but default Apple folders may fail until the permission is granted.";
"welcome.fda.recheck" = "Recheck permission";
"welcome.fda.step1" = "Open System Settings → Privacy & Security → Full Disk Access";
"welcome.fda.step2" = "Click the + button and add IPSW Downloader Plus";
"welcome.fda.step3" = "Enable the toggle next to the app, then return here and click \"Recheck permission\"";
"fda.required.title" = "Full Disk Access Required";
"fda.required.body" = "IPSW Downloader Plus writes firmware directly into your real user Library folders, like ~/Library/iTunes and Apple Configurator's firmware cache. Grant Full Disk Access before using the app.";
"fda.required.quit" = "Quit";
"welcome.folders.title" = "Managed folders";
"welcome.folders.itunes.title" = "iPhone · iPad · iPod touch";
"welcome.folders.itunes.desc" = "Saved in iTunes Software Updates — detected by both Finder and Apple Configurator.";
"welcome.folders.configurator.title" = "Apple TV · HomePod mini · Apple Vision · T2 Mac (iBridge) · Apple Silicon Mac";
"welcome.folders.configurator.desc" = "Saved in the Apple Configurator Firmware folder. Apple Configurator does NOT detect firmware for these devices in the iTunes folder.";
"welcome.folders.show_in_finder" = "Show in Finder";
"welcome.reorganize.title" = "Automatic management of existing files";
"welcome.reorganize.body" = "By accepting, IPSW Downloader Plus will take over management of these two folders. Existing .ipsw files will be reorganized automatically:";
"welcome.reorganize.bullet1" = "iPhone/iPad/iPod firmware found in the Configurator folder will be moved to the correct iTunes folder.";
"welcome.reorganize.bullet2" = "Apple TV, HomePod, Mac firmware found in the iTunes folder will be moved to the Configurator folder.";
"welcome.reorganize.bullet3" = "Firmware still signed by Apple but not updated will be left unchanged.";
"welcome.reorganize.bullet4" = "Firmware no longer signed by Apple will be deleted or moved to Trash (according to your settings).";
"welcome.reorganize.bullet5" = "Whenever a newer version is downloaded, the previous one will be removed.";
"welcome.excluded.title" = "Automatically excluded devices";
"welcome.excluded.body" = "The following devices are always ignored because they are irrelevant or stuck on outdated versions:";
"welcome.excluded.bullet1" = "ADP3,2 — Apple Silicon Developer Transition Kit (stuck on macOS 11.2.3, not upgradeable)";
"welcome.excluded.bullet2" = "VirtualMac — Apple Silicon Virtual Machine (redundant virtual instance)";
"welcome.schedule.title" = "Automatic scheduling — important notes";
"welcome.schedule.warning" = "For the scheduled automatic launch feature, Automatic Login must be enabled on the Mac (System Settings → Users & Groups). Without automatic login, the Mac cannot run scheduled tasks when shut down or restarted.";
"welcome.schedule.body" = "The scheduling uses a macOS LaunchAgent (~/Library/LaunchAgents/com.icosisenpai.ipsw-downloader-plus.plist) that launches the app at the configured time. Only signed and active downloads are executed.";
"welcome.security.title" = "Security & verification";
"welcome.security.bullet1" = "All firmware is downloaded only from official Apple CDNs (appldnld.apple.com, updates.cdn-apple.com).";
"welcome.security.bullet2" = "After each download, the SHA1 checksum provided by the ipsw.me API is verified.";
"welcome.security.bullet3" = "Files with incorrect size or checksum are automatically discarded and re-downloaded.";
"welcome.security.fda_required.title" = "Full Disk Access is mandatory for default folders";
"welcome.security.fda_required.body" = "If you want IPSW Downloader Plus to save directly into the default iTunes and Apple Configurator folders, Full Disk Access is required. Without it, the app can't write there.";
"welcome.security.fda_required.custom" = "A custom destination is active at %@. In this case the app can save there even without Full Disk Access, but it will no longer use Apple's default folders.";
"welcome.custom_folder.warning_title" = "Custom destination";
"welcome.custom_folder.warning_body" = "You can change the default destination folder in Settings. If you do, downloads will stop going to the default iTunes and Apple Configurator folders.";
"welcome.custom_folder.warning_settings" = "You can override the default folders from Settings if you prefer saving all firmware elsewhere.";
"welcome.custom_folder.warning_active" = "A custom destination is already active: %@. Downloads will go there instead of the default Apple folders.";
